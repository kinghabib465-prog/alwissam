# ============================================================
# عيادة الوسام — إعداد إنتاج Contabo / VPS
# انسخ إلى .env في جذر المشروع:  cp deploy/contabo/.env.production.example .env
# ============================================================

# --- عنوان الموقع (مهم جداً) ---
# نطاق العيادة مع https — مثال: https://alwisam.example.dz
# للتجربة بـ IP فقط: http://YOUR_SERVER_IP  و COOKIE_SECURE=false
NEXT_PUBLIC_APP_URL=https://alwisam.example.dz
DOMAIN=alwisam.example.dz
ACME_EMAIL=admin@alwisam.dz
APP_NAME=عيادة الوسام لطب الأسنان

# --- قاعدة البيانات (داخل Docker — لا تغيّر المضيف) ---
POSTGRES_USER=alwisam
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_32CHARS
POSTGRES_DB=alwisam_dental

# --- أسرار التطبيق (شغّل: bash deploy/contabo/generate-secrets.sh) ---
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_64_CHARS
CSRF_SECRET=CHANGE_ME_CSRF_SECRET_64_CHARS
SIGNED_URL_SECRET=CHANGE_ME_SIGNED_URL_SECRET_64_CHARS
COOKIE_SECURE=true

# --- حسابات الدخول الأولية (غيّرها قبل التسليم للعيادة) ---
SEED_DOCTOR_SPECIALIST_EMAIL=manana@alwisam.dz
SEED_DOCTOR_SPECIALIST_PHONE=0550000003
SEED_DOCTOR_SPECIALIST_PASSWORD=ChangeMe_Manana_2026!

SEED_SECRETARY1_EMAIL=samar@alwisam.dz
SEED_SECRETARY1_PHONE=0550000002
SEED_SECRETARY1_PASSWORD=ChangeMe_Samar_2026!

SEED_DOCTOR_GENERAL_EMAIL=wakri@alwisam.dz
SEED_DOCTOR_GENERAL_PHONE=0550000004
SEED_DOCTOR_GENERAL_PASSWORD=ChangeMe_Wakri_2026!

# --- البريد (مطلوب لنسيان كلمة المرور وتفعيل المرضى) ---
# خيار A — Brevo API (مفتاح xkeysib- من SMTP & API → API keys)
BREVO_API_KEY=
# يجب أن يكون بريداً موثّقاً في Brevo → Senders
EMAIL_FROM=your-verified-sender@email.com
SMTP_FROM=your-verified-sender@email.com

# خيار B — SMTP (إن فضّلت مفتاح xsmtpsib- بدل API)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=your-verified-sender@email.com

# خيار C — Resend
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=عيادة الوسام <onboarding@resend.dev>

# --- بيانات العيادة (الموقع العام) ---
CLINIC_PHONE=0550000000
CLINIC_EMAIL=contact@alwisam.dz
CLINIC_ADDRESS=الجزائر

# --- اختياري ---
SESSION_MAX_AGE_HOURS=12
SESSION_REMEMBER_DAYS=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30
MAX_UPLOAD_SIZE_MB=20
